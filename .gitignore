name: "Z-Kinetic Final Release (APK, AAR & iOS SDK)"
on:
  workflow_dispatch:
  push:
    branches: [ main, master ]

jobs:
  # ==============================================================
  # KILANG 1: ANDROID (BUAT APK & AAR)
  # ==============================================================
  build-android:
    name: "🤖 Build Android (APK & AAR)"
    runs-on: ubuntu-latest
    permissions:
      contents: write
    
    steps:
      - name: "📥 Checkout Repository"
        uses: actions/checkout@v4

      - name: "☕ Setup Java 17"
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '17'

      - name: "🦅 Setup Flutter (Stable)"
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'
          cache: true

      - name: "🔥 Nuclear Clean & Create MODULE"
        run: |
          echo "==> Padam folder lama..."
          rm -rf android/ ios/ build/ .dart_tool/ pubspec.lock
          echo "==> Buat projek sebagai MODULE (Wajib untuk buat AAR)..."
          flutter create --template=module --org com.aer --project-name zkinetic .

      - name: "🔓 Inject Network Permissions (Fix Loading)"
        run: |
          echo "==> Masukkan permission kat folder .android..."
          # Folder untuk module ada kat .android (folder tersorok)
          sed -i 's|<application|<uses-permission android:name="android.permission.INTERNET"/>\n    <application|' .android/app/src/main/AndroidManifest.xml
          sed -i 's|android:label=|android:usesCleartextTraffic="true"\n        android:label=|' .android/app/src/main/AndroidManifest.xml

      - name: "🩹 Fix Dependency Versions"
        run: |
          sed -i 's/screen_protector: .*/screen_protector: ^1.5.1/' pubspec.yaml || true
          flutter pub get

      - name: "🔥 Generate Firebase Options Dummy"
        run: |
          mkdir -p lib
          cat > lib/firebase_options.dart << 'EOF'
          import 'package:firebase_core/firebase_core.dart' show FirebaseOptions;
          import 'package:flutter/foundation.dart' show defaultTargetPlatform, kIsWeb, TargetPlatform;

          class DefaultFirebaseOptions {
            static FirebaseOptions get currentPlatform {
              if (kIsWeb) throw UnsupportedError('Web not configured');
              switch (defaultTargetPlatform) {
                case TargetPlatform.android:
                  return android;
                default:
                  throw UnsupportedError('Platform not supported');
              }
            }

            static const FirebaseOptions android = FirebaseOptions(
              apiKey: 'AIzaSyDej3jrmqkUYyCs8CYepwdbrlInSBNWt_w',
              appId: '1:55621733629:android:ef51c1276ef226b0408294',
              messagingSenderId: '55621733629',
              projectId: 'z-kinetic',
              storageBucket: 'z-kinetic.firebasestorage.app',
            );
          }
          EOF

      # 1. BUAT APK (UNTUK BOS TEST)
      - name: "🚀 Build APK (Maggi Edition)"
        run: flutter build apk --release --obfuscate --split-debug-info=build/apk_symbols --no-tree-shake-icons

      # 2. BUAT AAR (UNTUK JUAL KAT KLIEN ANDROID)
      - name: "📦 Build AAR (Maggi Edition)"
        run: flutter build aar --obfuscate --split-debug-info=build/aar_symbols

      - name: "📤 Upload Android Artifacts (APK + AAR)"
        uses: actions/upload-artifact@v4
        with:
          name: z-kinetic-android-bundle
          path: |
            build/**/outputs/**/*.apk
            build/host/outputs/repo/
            build/apk_symbols/
            build/aar_symbols/


  # ==============================================================
  # KILANG 2: iOS (BUAT XCFRAMEWORK)
  # ==============================================================
  build-ios:
    name: "🍎 Build iOS (XCFramework)"
    runs-on: macos-latest
    permissions:
      contents: write

    steps:
      - name: "📥 Checkout Repository"
        uses: actions/checkout@v4

      - name: "🦅 Setup Flutter (Stable)"
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'
          cache: true

      - name: "🔥 Nuclear Clean & Create MODULE"
        run: |
          rm -rf android/ ios/ build/ .dart_tool/ pubspec.lock
          flutter create --template=module --org com.aer --project-name zkinetic .

      - name: "🩹 Fix Dependency Versions"
        run: |
          # Mac pakai 'sed -i ''' berbanding Linux
          sed -i '' 's/screen_protector: .*/screen_protector: ^1.5.1/' pubspec.yaml || true
          flutter pub get

      - name: "🔥 Generate Firebase Options Dummy"
        run: |
          mkdir -p lib
          cat > lib/firebase_options.dart << 'EOF'
          import 'package:firebase_core/firebase_core.dart' show FirebaseOptions;
          import 'package:flutter/foundation.dart' show defaultTargetPlatform, kIsWeb, TargetPlatform;

          class DefaultFirebaseOptions {
            static FirebaseOptions get currentPlatform {
              if (kIsWeb) throw UnsupportedError('Web not configured');
              switch (defaultTargetPlatform) {
                case TargetPlatform.android:
                  return android;
                default:
                  throw UnsupportedError('Platform not supported');
              }
            }

            static const FirebaseOptions android = FirebaseOptions(
              apiKey: 'AIzaSyDej3jrmqkUYyCs8CYepwdbrlInSBNWt_w',
              appId: '1:55621733629:android:ef51c1276ef226b0408294',
              messagingSenderId: '55621733629',
              projectId: 'z-kinetic',
              storageBucket: 'z-kinetic.firebasestorage.app',
            );
          }
          EOF

      # 3. BUAT iOS FRAMEWORK (UNTUK JUAL KAT KLIEN APPLE)
      - name: "📦 Build iOS Framework (Maggi Edition)"
        run: flutter build ios-framework --obfuscate --split-debug-info=build/ios_symbols

      - name: "📤 Upload iOS Framework Artifacts"
        uses: actions/upload-artifact@v4
        with:
          name: z-kinetic-ios-bundle
          path: |
            build/ios/framework/
            build/ios_symbols/
